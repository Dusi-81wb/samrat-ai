# ─── Performance Parameters ────────────────────────────────

# Creativity vs Focus (0.0=focused, 1.0=creative)
# 0.6 is sweet spot for reasoning — not too rigid, not too random
PARAMETER temperature 0.6

# Vocabulary diversity — 0.9 keeps good word variety
PARAMETER top_p 0.9

# Only consider top 40 token candidates — improves coherence
PARAMETER top_k 40

# Context window — max tokens model can see at once
# 8192 is optimal for 3B model on limited RAM
PARAMETER num_ctx 8192

# Penalize repeating same phrases — keeps responses fresh
PARAMETER repeat_penalty 1.1

# How far back to check for repetition (in tokens)
PARAMETER repeat_last_n 64

# Number of tokens to predict per response
PARAMETER num_predict 2048

